# Vendored sample repo (a git clone of zlib) — re-fetch instead of committing.
# Reproduce with: git clone https://github.com/madler/zlib first_example/zlib
first_example/zlib/

# Generated dataset artifacts (reproducible via the pipeline)
dataset/*.db
dataset/*.db-journal
dataset/*.db-wal
dataset/*.db-shm
dataset/*.sqlite

# dbgraph working output (the curated copy is committed under db-graph/)
dataset/dbgraph-out/

