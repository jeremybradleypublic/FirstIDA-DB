*.o
*.obj
scratch/
build/
.superpowers/
tests/tmp*/

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# OS
.DS_Store

# Collection activity log (runtime)
dataset/*.jsonl
